# GitHub token do checkoutu PR #21343 (opcjonalny)
# GH_TOKEN=ghp_xxxxx

# Model (HuggingFace repo:quant) - DOMYŚLNY: Qwen3.6 35B-A3B MTP UD-Q4_K_M
MODEL=unsloth/Qwen3.6-35B-A3B-MTP-GGUF:UD-Q4_K_M

# Server
PORT=8089
HOST=0.0.0.0

# Context size - DOMYŚLNY: 128K
CTX=131072

# GPU layers
NGLAYERS=999

# MoE experts on CPU
CPUMOE=exps=CPU

# Flash Attention (on/off/auto)
FLASHATTN=on

# Batch sizes - OPTYMALIZACJA
BATCH=1024
UBATCH=1024

# CPU threads
THREADS=6

# OPTYMALIZACJE
THREADS_BATCH=6
PARALLEL=2
POLL=50

# Disable server-side token cap
N_PREDICT=-1

# MTP speculative decoding
SPEC_TYPE=draft-mtp
SPEC_DRAFT_N_MAX=1

# KV cache - Q4 oszczędza VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0
