# GitHub token do checkoutu PR #21343 (opcjonalny)
# GH_TOKEN=ghp_xxxxx

# Model (HuggingFace repo:quant) - DOMYŚLNY: E2B UD-Q4_K_XL
MODEL=unsloth/gemma-4-E2B-it-GGUF:UD-Q4_K_XL

# Server
PORT=8089
HOST=0.0.0.0

# Context size - DOMYŚLNY: 128K dla E2B
CTX=131072

# GPU layers (999 = all, 0 = CPU only) - DOMYŚLNY: 999 (all)
NGLAYERS=999

# MoE experts on CPU (exps=CPU or empty) - NIE UŻYWANE dla E2B
CPUMOE=

# Flash Attention (on/off/auto)
FLASHATTN=on

# Batch sizes - OPTYMALIZACJA
BATCH=1024
UBATCH=1024

# CPU threads
THREADS=6

# OPTYMALIZACJE
THREADS_BATCH=6
PARALLEL=4
POLL=100

# KV cache - Q4 oszczędza VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0