# ═══════════════════════════════════════════════════════════════════════
# Fresh Proxmox Install — Configuration
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to config.env, edit values to match your environment,
# then run: bash install-all.sh
# ═══════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────
# LXC target (the container that will run llama.cpp)
# ──────────────────────────────────────────────
VMID="1004"
LXC_HOSTNAME="llama"
LXC_IP="192.168.200.38"
CIDR="24"
GATEWAY="192.168.200.1"
BRIDGE="vmbr0"
STORAGE="local-zfs"              # Proxmox storage for container rootfs
TEMPLATE=""                      # Leave empty to auto-detect latest Debian 13 template
CORES="6"
MEMORY_MB="24576"                # 24 GB
DISK_GB="40"

# ──────────────────────────────────────────────
# Proxmox host
# ──────────────────────────────────────────────
HOST_NODE="$(hostname -s)"       # Auto-detected; override if needed

# ──────────────────────────────────────────────
# Llama.cpp application
# ──────────────────────────────────────────────
PROJECT_DIR="/opt/llama"
APP_PORT="8089"
LLAMA_REPO="https://github.com/ggml-org/llama.cpp.git"
LLAMA_REF="master"
REPO_URL="https://github.com/noxgle/llama.git"
REPO_BRANCH="master"
ACTIVE_CONFIG="configs/qwen3.6-35ba3b-mtp-unsloth.env"  # Relative to repo root

# ──────────────────────────────────────────────
# Bootstrap options
# ──────────────────────────────────────────────
ENABLE_WATCHDOG="true"           # Deploy GPU watchdog systemd timer
ENABLE_POSTBOOT_RESTART="true"   # Add delayed compose restart after boot
SKIP_BUILD="false"               # Set true to skip docker build (use prebuilt image)
INSTALL_LOG="install.log"        # Log file path (relative to script dir)
