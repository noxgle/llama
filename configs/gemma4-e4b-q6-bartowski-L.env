# Gemma 4 E4B IT Q6_K_L - bartowski imatrix quant
# Nowy config z Q6_K_L (lepsza jakość przez imatrix)
# Test VRAM: start z NGLAYERS=25

# Model - bartowski Q6_K_L (imatrix)
MODEL=bartowski/google_gemma-4-E4B-it-GGUF:Q6_K_L

# Server
PORT=8089
HOST=0.0.0.0

# Context - 64K (bez zmian)
CTX=65536

# GPU layers - STARTOWY test (25 warstw na GPU)
# Testować: 25 -> 30 -> 35
NGLAYERS=25

# Flash Attention ON
FLASHATTN=on

# Batch sizes - OPTYMALIZACJA: zwiększone do 1024
BATCH=1024
UBATCH=1024

# CPU threads - OPTYMALIZACJA: 6
THREADS=6
THREADS_BATCH=6
PARALLEL=4
POLL=100

# KV cache - Q4 oszczędza VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0