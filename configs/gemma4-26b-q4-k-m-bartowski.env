# Gemma 4 26B-A4B IT Q4_K_M - Bartowski

# Model - Bartowski imatrix quant
MODEL=bartowski/google_gemma-4-26B-A4B-it-GGUF:Q4_K_M

# Server
PORT=8089
HOST=0.0.0.0

# Context
CTX=65536

# Disable server-side token cap (infinite generation unless client caps)
N_PREDICT=-1

# GPU layers - full GPU offload request
NGLAYERS=999

# MoE experts on CPU
CPUMOE=exps=CPU

# Flash Attention
FLASHATTN=on

# Runtime
BATCH=1024
UBATCH=1024
THREADS=6
THREADS_BATCH=6
PARALLEL=2
POLL=50

# Load full model to RAM (disable mmap)
MMAP_FLAG=--no-mmap

# Speculative decoding draft model (Gemma 4 assistant)
SPEC_DRAFT_HF_REPO=google/gemma-4-26B-A4B-it-assistant
SPEC_DRAFT_N_MAX=8
SPEC_DRAFT_N_MIN=2
SPEC_DRAFT_P_MIN=0.75

# KV cache quantization
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0
