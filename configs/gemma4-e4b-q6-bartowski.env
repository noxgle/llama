# Gemma 4 E4B IT Q6_K - bartowski quant (same params as Q5)

# Model - bartowski Q6_K
MODEL=bartowski/google_gemma-4-E4B-it-GGUF:Q6_K

# Server
PORT=8089
HOST=0.0.0.0

# Context - 64K (same as Q5)
CTX=65536

# GPU layers - 42 all on GPU (same as Q5)
NGLAYERS=42

# Flash Attention ON
FLASHATTN=on

# Batch sizes (same as Q5)
BATCH=512
UBATCH=512

# CPU threads - 1 for GPU focus (same as Q5)
THREADS=1

# KV cache - Q4 saves VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0