# Qwen3.6 35B-A3B MTP - Speculative decoding (upstream PR #22673)

# Target model (MTP head embedded in same GGUF)
MODEL=unsloth/Qwen3.6-35B-A3B-MTP-GGUF:UD-Q4_K_M

# Server
PORT=8089
HOST=0.0.0.0

# Context (160K — compromise between VRAM headroom and context size, ~5550/6144 MiB @ q4_0 kv cache)
CTX=163840

# Disable server-side token cap
N_PREDICT=-1

# GPU layers - offload as many as possible, rest in RAM
NGLAYERS=999

# MoE experts on CPU (MoE model, most experts stay in RAM)
CPUMOE=exps=CPU

# Flash Attention
FLASHATTN=on

# Runtime
BATCH=512
UBATCH=512
THREADS=6
THREADS_BATCH=6
PARALLEL=1
POLL=50

# Memory
MMAP_FLAG=--no-mmap

# KV cache quantization
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0

# KV context checkpoints (fewer = less RAM, more reprocessing)
CTX_CHECKPOINTS=4

# MTP speculative decoding
SPEC_TYPE=draft-mtp
SPEC_DRAFT_N_MAX=2
