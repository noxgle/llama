# Router mode — llama-server without a fixed model
# Loads/unloads models dynamically via POST /models/load
# Model definitions in router-preset.ini (mounted at /configs/)

# Server
PORT=8089
HOST=0.0.0.0

# Runtime
THREADS=6
THREADS_BATCH=6
PARALLEL=1
POLL=50

# Router config
MODELS_PRESET=/configs/router-preset.ini
MODELS_MAX=4
