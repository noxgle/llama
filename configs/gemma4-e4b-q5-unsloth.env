# Gemma 4 E4B IT Q5_K_M (unsloth)

# Model - unsloth Q5
MODEL=unsloth/gemma-4-E4B-it-GGUF:Q5_K_M

# Server
PORT=8089
HOST=0.0.0.0

# Context - 64K
CTX=65536

# GPU layers - 42 (all on GPU)
NGLAYERS=42

# Flash Attention ON
FLASHATTN=on

# Batch sizes
BATCH=512
UBATCH=512

# CPU threads - 1 for GPU focus
THREADS=1

# Q4 KV cache - oszczędza VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0
