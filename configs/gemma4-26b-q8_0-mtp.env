# Gemma 4 26B A4B MoE - UD-Q8_K_XL + Q8_0-MTP draft (draft-mtp)
# Main model: Unsloth Dynamic Q8_K_XL (~27.6 GB, near-lossless, ~11 tok/s)
# Draft: Q8_0-MTP (separate draft head GGUF, ~462 MB, ~90% accept)
# WARNING: ~27/30 GB RAM (very tight, only ~3-4 Gi available)
# Flags: MODEL_FLAG=-m, DRAFT_FLAG=-md (bypasses get_hf_plan bug)

# Main model - lokalna ściezka do cache HF (przez symlink)
MODEL_FLAG=-m
MODEL=/models/gemma4-26b-q8-k-xl.gguf

# Server
PORT=8089
HOST=0.0.0.0

# Context - conservative (oszczednosc RAM)
CTX=16384

# Disable server-side token cap
N_PREDICT=-1

# GPU layers - minimal offload (Q8 warstwy ~2x wieksze niz Q4)
NGLAYERS=10

# MoE experts on CPU
CPUMOE=exps=CPU

# Flash Attention
FLASHATTN=on

# Batch sizes - minimalne
BATCH=128
UBATCH=128

# CPU threads
THREADS=6
THREADS_BATCH=6
PARALLEL=1
POLL=50

# KV cache quantization
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0

# KV cache in system RAM (MB) — reduces VRAM pressure for long contexts
CACHE_RAM=4096

# KV cache reuse window (tokens) — reuse KV from recent requests
CACHE_REUSE=256

# KV context checkpoints (more = faster reprocessing, more RAM)
CTX_CHECKPOINTS=8

# MTP speculative decoding - draft-mtp
SPEC_TYPE=draft-mtp
SPEC_DRAFT_N_MAX=2
SPEC_DRAFT_N_MIN=1
SPEC_DRAFT_P_MIN=0.75
DRAFT_FLAG=-md
DRAFT_MODEL=/models/gemma4-26b-q8-mtp.gguf
GPU_LAYERS_DRAFT=0
