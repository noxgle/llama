# Qwen3.6 35B-A3B MTP Q5_K_M - Speculative decoding (upstream PR #22673)
# Higher quality than Q4_K_M, but ~10% slower throughput and +900 MiB VRAM idle.
# Model file: Qwen3.6-35B-A3B-UD-Q5_K_M.gguf (26 GB, see install-llama.sh qwen-q5)

# Target model (local GGUF file — download via curl, see install-llama.sh qwen-q5)
MODEL_FLAG=-m
MODEL=/models/qwen-q5-k-m.gguf

# Server
PORT=8089
HOST=0.0.0.0

# Context (160K — compromise between VRAM headroom and context size)
CTX=143360

# Disable server-side token cap
N_PREDICT=-1

# GPU layers - offload as many as possible, rest in RAM
NGLAYERS=999

# MoE experts on CPU (MoE model, most experts stay in RAM)
CPUMOE=exps=CPU

# Flash Attention
FLASHATTN=on

# Runtime
BATCH=3072
UBATCH=1536
# LXC has only 4 CPUs (verified 2026-06-26), see cpuset.cpus.effective
THREADS=4
THREADS_BATCH=4
PARALLEL=1
POLL=50

# Memory
MMAP_FLAG=--no-mmap

# KV cache quantization
CACHE_TYPE_K=q8_0
CACHE_TYPE_V=q8_0

# KV cache in system RAM (MB) — reduces VRAM pressure for long contexts
CACHE_RAM=3072

# KV cache reuse window (tokens) — reuse KV from recent requests
CACHE_REUSE=256

# KV context checkpoints (more = faster reprocessing, more RAM)
CTX_CHECKPOINTS=10

# MTP speculative decoding
SPEC_TYPE=draft-mtp
SPEC_DRAFT_N_MAX=1
