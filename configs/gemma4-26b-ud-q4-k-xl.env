# Gemma 4 26B-A4B IT UD-Q4_K_XL - quality-first candidate

# Model - Unsloth Dynamic Q4_K_XL (MoE)
MODEL=unsloth/gemma-4-26B-A4B-it-GGUF:UD-Q4_K_XL

# Server
PORT=8089
HOST=0.0.0.0

# Context - 64K per request
CTX=65536

# Disable server-side token cap (infinite generation unless client caps)
N_PREDICT=-1

# GPU layers - full offload request
NGLAYERS=999

# MoE experts on CPU
CPUMOE=exps=CPU

# Flash Attention
FLASHATTN=on

# Runtime (conservative for VRAM at 64K)
BATCH=1024
UBATCH=1024
THREADS=6

# KV cache quantization
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0
