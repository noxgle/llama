# Default .env file (Gemma 4 E4B IT - current config)

# Model
MODEL=ggml-org/gemma-4-E4B-it-GGUF:Q4_K_M

# Server
PORT=8089
HOST=0.0.0.0

# Context
CTX=32768

# GPU
NGLAYERS=50

# MoE experts on CPU (saves VRAM)
CPUMOE=exps=CPU

# Flash Attention (off for GTX 1060)
FLASHATTN=off

# Batch sizes
BATCH=256
UBATCH=256

# CPU threads
THREADS=6
