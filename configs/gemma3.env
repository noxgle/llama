# Gemma 3 - smaller model, can use more GPU layers

MODEL=google/gemma-3-4b-it-GGUF:Q4_K_M

PORT=8089
HOST=0.0.0.0

CTX=32768

NGLAYERS=999  # all layers on GPU

CPUMOE=
FLASHATTN=on  # Gemma 3 supports FA better

BATCH=512
UBATCH=512

THREADS=6

# Q4 KV cache - oszczędza VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0