# Gemma 4 E4B IT Q5_K_M (unsloth)

# Model - unsloth Q5
MODEL=unsloth/gemma-4-E4B-it-GGUF:Q8_K_M

# Server
PORT=8089
HOST=0.0.0.0

# Context - 64K
CTX=65536

# GPU layers - 30 na GPU
NGLAYERS=30

# Flash Attention ON
FLASHATTN=on

# Batch sizes - zwiększone
BATCH=512
UBATCH=512

# CPU threads
THREADS=6

# Q4 KV cache - oszczędza VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0
