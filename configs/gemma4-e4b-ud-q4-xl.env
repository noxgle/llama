# Gemma 4 E4B IT UD-Q4_K_XL - Unsloth Dynamic 2.0

# Model - Unsloth UD-Q4_K_XL (Ultra Dynamic - najwyższa jakość 4-bit)
# E4B = 4B effective params
MODEL=unsloth/gemma-4-E4B-it-GGUF:UD-Q4_K_XL

# Server
PORT=8089
HOST=0.0.0.0

# Context - 128K (E4B supports up to 128K)
CTX=131072

# GPU layers - mniej niż E2B bo większy model
NGLAYERS=40

# Flash Attention ON
FLASHATTN=on

# Batch sizes
BATCH=1024
UBATCH=1024

# CPU threads
THREADS=6

# OPTYMALIZACJE
THREADS_BATCH=6
PARALLEL=4
POLL=100

# KV cache - Q4 oszczędza VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0