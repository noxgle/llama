# Gemma 4 26B-A4B IT UD-IQ2_XXS - Unsloth Dynamic 2.0
# Uwaga: MoE model - partial offload wymagany!

# Model - Unsloth UD-IQ2_XXS (najmniejszy quant)
# 26B-A4B = 26B total, 4B active (MoE)
MODEL=unsloth/gemma-4-26B-A4B-it-GGUF:UD-IQ2_XXS

# Server
PORT=8089
HOST=0.0.0.0

# Context - 256K (max for 26B)
CTX=262144

# GPU layers - 20 (partial offload dla MoE)
NGLAYERS=20

# MoE experts on CPU - KLUCZOWE dla MoE!
CPUMOE=exps=CPU

# Flash Attention ON
FLASHATTN=on

# Batch sizes
BATCH=512
UBATCH=512

# CPU threads
THREADS=6

# OPTYMALIZACJE
THREADS_BATCH=6
PARALLEL=4
POLL=100

# KV cache - Q4 oszczędza VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0