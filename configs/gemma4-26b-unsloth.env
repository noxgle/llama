# Gemma 4 26B A4B (MoE) - GTX 1060 6GB
# CTX=32K, BATCH=128, NGLAYERS=30, FA=on, Q4_KV_CACHE

# Model
MODEL=unsloth/gemma-4-26B-A4B-it-GGUF:Q4_K_M

# Server
PORT=8089
HOST=0.0.0.0

# Context - 32K
CTX=32768

# GPU layers - wszystkie na GPU!
NGLAYERS=30

# MoE experts na CPU
CPUMOE=exps=CPU

# Flash Attention ON
FLASHATTN=on

# Batch sizes
BATCH=128
UBATCH=128

# CPU threads
THREADS=6

# Q4 KV cache
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0