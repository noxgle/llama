# Gemma 4 E4B IT Q8_K_M (higher precision)

# Model
MODEL=ggml-org/gemma-4-E4B-it-GGUF:Q8_K_M

# Server
PORT=8089
HOST=0.0.0.0

# Context
CTX=32768

# GPU
NGLAYERS=50

# MoE experts on CPU (saves VRAM)
CPUMOE=exps=CPU

# Flash Attention ON - for better performance and Q4 KV cache
FLASHATTN=on

# Batch sizes
BATCH=256
UBATCH=256

# CPU threads
THREADS=6

# Q4 KV cache - oszczędza VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0