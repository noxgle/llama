# Gemma 4 26B A4B MoE - UD-Q4_K_M + Q8_0-MTP draft (draft-mtp)
# Main model: Unsloth Dynamic Q4_K_M (~17 GB, ~21 tok/s @ 128K)
# Draft: Q8_0-MTP (separate draft head GGUF, ~462 MB, ~90% accept)
# Flags: MODEL_FLAG=-m, DRAFT_FLAG=-md (bypasses get_hf_plan bug)
# Docs: see AGENTS.md "Gemma 4 test results" section

# Main model - lokalna ściezka do cache HF (przez symlink)
MODEL_FLAG=-m
MODEL=/models/gemma4-26b-q4-k-m.gguf

# Server
PORT=8089
HOST=0.0.0.0

# Context - 128K (15/30 GB RAM used, 4.8/6 GB VRAM)
CTX=131072

# Disable server-side token cap
N_PREDICT=-1

# GPU layers - full offload (non-expert layers on GPU, experts via CPUMOE)
NGLAYERS=999

# MoE experts on CPU
CPUMOE=exps=CPU

# Flash Attention
FLASHATTN=on

# Batch sizes
BATCH=512
UBATCH=512

# CPU threads
THREADS=6
THREADS_BATCH=6
PARALLEL=1
POLL=50

# KV cache quantization
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0

# KV context checkpoints
CTX_CHECKPOINTS=4

# MTP speculative decoding - draft-mtp (NOT draft-simple, crashuje na PR #20277)
SPEC_TYPE=draft-mtp
SPEC_DRAFT_N_MAX=2
SPEC_DRAFT_N_MIN=1
SPEC_DRAFT_P_MIN=0.75
DRAFT_FLAG=-md
DRAFT_MODEL=/models/gemma4-26b-q8-mtp.gguf
# Draft model on GPU (462 MB Q8_0, ~1.2 GB free VRAM should fit)
GPU_LAYERS_DRAFT=99
