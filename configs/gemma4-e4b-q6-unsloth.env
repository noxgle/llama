# Gemma 4 E4B IT Q6_K

# Model - Q6_K (kompresja)
MODEL=unsloth/gemma-4-E4B-it-GGUF:Q6_K

# Server
PORT=8089
HOST=0.0.0.0

# Context - 64K
CTX=65536

# GPU layers - 15 na GPU
NGLAYERS=15

# Flash Attention ON
FLASHATTN=on

# Batch sizes
BATCH=128
UBATCH=128

# CPU threads
THREADS=6

# KV cache - Q4 dla oszczędności VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0