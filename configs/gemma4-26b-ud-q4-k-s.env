# Gemma 4 26B-A4B IT UD-Q4_K_S - quality-first candidate

# Model - Unsloth Dynamic Q4_K_S (MoE)
MODEL=unsloth/gemma-4-26B-A4B-it-GGUF:UD-Q4_K_S

# Server
PORT=8089
HOST=0.0.0.0

# Context - 32K for stable quality on 26B MoE
CTX=32768

# Disable server-side token cap (infinite generation unless client caps)
N_PREDICT=-1

# GPU layers - quality-first, offload as much as possible
NGLAYERS=30

# MoE experts on CPU
CPUMOE=exps=CPU

# Flash Attention
FLASHATTN=on

# Runtime
BATCH=1024
UBATCH=1024
THREADS=6

# KV cache quantization
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0
