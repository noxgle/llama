# Gemma 4 E4B IT Q5_K_M - bartowski quant (same params as unsloth Q5)

# Model - bartowski Q5
MODEL=bartowski/google_gemma-4-E4B-it-GGUF:Q5_K_M

# Server
PORT=8089
HOST=0.0.0.0

# Context - 64K (same as unsloth Q5)
CTX=65536

# GPU layers - 42 all on GPU (same as unsloth Q5)
NGLAYERS=42

# Flash Attention ON
FLASHATTN=on

# Batch sizes (same as unsloth Q5)
BATCH=512
UBATCH=512

# CPU threads - 1 for GPU focus (same as unsloth Q5)
THREADS=1

# KV cache - Q4 saves VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0