# Gemma 4 E4B IT Q5_K_M - bartowski imatrix quant (OPTYMALIZOWANY)

# Model - bartowski Q5_K_M (imatrix - lepsza jakość)
MODEL=bartowski/google_gemma-4-E4B-it-GGUF:Q5_K_M

# Server
PORT=8089
HOST=0.0.0.0

# Context - 64K
CTX=65536

# GPU layers - 42 all on GPU
NGLAYERS=42

# Flash Attention ON
FLASHATTN=on

# Batch sizes - OPTYMALIZACJA: zwiększone do 1024
BATCH=1024
UBATCH=1024

# CPU threads - OPTYMALIZACJA: 6
THREADS=6

# OPTYMALIZACJE: nowe parametry
THREADS_BATCH=6
PARALLEL=2
POLL=100

# KV cache - Q4 oszczędza VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0