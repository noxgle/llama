# Gemma 4 E2B IT UD-Q4_K_XL - Unsloth Dynamic 2.0 (ULTRA KOMPAKTOWY)

# Model - Unsloth UD-Q4_K_XL (Ultra Dynamic - najwyższa jakość przy 4-bit)
# E2B = 2B effective params (z PLE - Per-Layer Embeddings)
MODEL=unsloth/gemma-4-E2B-it-GGUF:UD-Q4_K_XL

# Server
PORT=8089
HOST=0.0.0.0

# Context - 128K (E2B supports up to 128K)
CTX=131072

# GPU layers - wszystkie na GPU (999 = all)
NGLAYERS=999

# Flash Attention ON
FLASHATTN=on

# Batch sizes - OPTYMALIZACJA: wysokie dla lepszej wydajności
BATCH=1024
UBATCH=1024

# CPU threads
THREADS=6

# OPTYMALIZACJE: nowe parametry
THREADS_BATCH=6
PARALLEL=4
POLL=100

# KV cache - Q4 oszczędza VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0