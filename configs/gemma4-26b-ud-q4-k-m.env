# Gemma 4 26B-A4B IT UD-Q4_K_M - quality-first baseline

# Model - Unsloth Dynamic Q4_K_M (MoE)
MODEL=unsloth/gemma-4-26B-A4B-it-GGUF:UD-Q4_K_M

# Server
PORT=8089
HOST=0.0.0.0

# Context
CTX=65536

# Disable server-side token cap (infinite generation unless client caps)
N_PREDICT=-1

# GPU layers - full GPU offload request
NGLAYERS=999

# MoE experts on CPU
CPUMOE=exps=CPU

# Flash Attention
FLASHATTN=on

# Runtime
BATCH=1024
UBATCH=1024
THREADS=6
THREADS_BATCH=6
PARALLEL=2
POLL=50

# Load full model to RAM (disable mmap)
MMAP_FLAG=--no-mmap

# KV cache quantization
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0
