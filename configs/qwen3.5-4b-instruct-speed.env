# Qwen 3.5 4B Instruct (Bartowski GGUF) - speed profile
# Stability target: <=90% VRAM on GTX 1060 6GB

MODEL=bartowski/Qwen_Qwen3.5-4B-GGUF:Q4_K_M

# Server
PORT=8089
HOST=0.0.0.0

# Context and GPU offload
CTX=65536
NGLAYERS=999

# Runtime options
FLASHATTN=on
BATCH=1024
UBATCH=1024
THREADS=6

# KV cache quantization to save VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0
