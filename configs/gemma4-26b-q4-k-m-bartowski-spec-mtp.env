# Gemma 4 26B-A4B IT Q4_K_M - Bartowski (Speculative MTP)
# Uses --spec-type mtp with AtomicChat gemma4_assistant draft GGUF

# Target model (same as stable baseline)
MODEL=bartowski/google_gemma-4-26B-A4B-it-GGUF:Q4_K_M

# Server
PORT=8089
HOST=0.0.0.0

# Context
CTX=65536

# Disable server-side token cap
N_PREDICT=-1

# GPU layers
NGLAYERS=999

# MoE experts on CPU
CPUMOE=exps=CPU

# Flash Attention
FLASHATTN=on

# Runtime
BATCH=1024
UBATCH=1024
THREADS=6
THREADS_BATCH=6
PARALLEL=2
POLL=50

# Load full model to RAM
MMAP_FLAG=--no-mmap

# KV cache quantization
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0

# MTP speculative decoding (Gemma 4 assistant head)
SPEC_TYPE=mtp
# MODEL_DRAFT must point to a local GGUF file path inside the container
# After first download via --hf-repo-draft, resolve via refs/main hash
MODEL_DRAFT=/root/.cache/huggingface/hub/models--AtomicChat--gemma-4-26B-A4B-it-assistant-GGUF/snapshots/171ecca181ec00ed6ffacb573195aa7c644bbdc6/gemma-4-26B-A4B-it-assistant.Q4_K_M.gguf
DRAFT_MAX=3
DRAFT_MIN=1
DRAFT_P_MIN=0.75
# Keep draft model on CPU to avoid OOM (GTX 1060 6GB is tight)
GPU_LAYERS_DRAFT=0
CTX_SIZE_DRAFT=4096
