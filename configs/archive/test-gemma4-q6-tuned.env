# Gemma 4 E4B IT Q6_K - OPTYMALIZOWANY (test config)
# Zmienione: THREADS=6, THREADS_BATCH, PARALLEL, POLL dla Q6_K

# Model - Q6_K (lepsza jakość)
MODEL=bartowski/google_gemma-4-E4B-it-GGUF:Q6_K

# Server
PORT=8089
HOST=0.0.0.0

# Context - 64K
CTX=65536

# GPU layers - 42 all on GPU
NGLAYERS=42

# Flash Attention ON
FLASHATTN=on

# Batch sizes
BATCH=512
UBATCH=512

# CPU threads - OPTYMALIZACJA: 6 (z 1 -> 6)
THREADS=6

# OPTYMALIZACJE: nowe parametry
THREADS_BATCH=6
PARALLEL=4
POLL=100

# KV cache - Q4 saves VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0
