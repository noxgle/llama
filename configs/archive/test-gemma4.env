# Gemma 4 E4B IT Q5_K_M - test config

# Model - Q5_K_M
MODEL=unsloth/gemma-4-E4B-it-GGUF:Q5_K_M

# Server
PORT=8089
HOST=0.0.0.0

# Context - 64K
CTX=65536

# GPU layers - 42 all on GPU
NGLAYERS=42

# Flash Attention ON
FLASHATTN=on

# Batch sizes
BATCH=512
UBATCH=512

# CPU threads
THREADS=1

# KV cache - Q4 saves VRAM
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0
