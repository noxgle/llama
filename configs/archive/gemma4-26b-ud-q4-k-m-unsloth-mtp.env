# Gemma 4 26B A4B MoE - Unsloth UD-Q4_K_M + Q8_0-MTP draft
# Main model: Unsloth Dynamic Q4_K_M (26B total / 4B active MoE)
# Draft: Unsloth Q8_0-MTP (separate draft head GGUF, ~1-2 GB)

# Main model
MODEL=unsloth/gemma-4-26B-A4B-it-GGUF:UD-Q4_K_M

# Server
PORT=8089
HOST=0.0.0.0

# Context - conservative start (32K, dostosuj po testach)
CTX=32768

# Disable server-side token cap
N_PREDICT=-1

# GPU layers - partial offload (26B total, ~16 GB GGUF, 6 GB VRAM)
NGLAYERS=20

# MoE experts on CPU (saves VRAM)
CPUMOE=exps=CPU

# Flash Attention
FLASHATTN=on

# Batch sizes - conservative for CPU-heavy MoE execution
BATCH=256
UBATCH=256

# CPU threads
THREADS=6
THREADS_BATCH=6
PARALLEL=1
POLL=50

# KV cache quantization
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0

# KV context checkpoints
CTX_CHECKPOINTS=4

# MTP - wylaczone (draft-simple crashuje na tym buildzie, PR #20277)
# Do wlaczenia po updacie llama.cpp
SPEC_TYPE=none
#SPEC_DRAFT_N_MAX=3
#SPEC_DRAFT_N_MIN=1
#SPEC_DRAFT_P_MIN=0.75
#DRAFT_MODEL=unsloth/gemma-4-26B-A4B-it-GGUF:Q8_0-MTP
#GPU_LAYERS_DRAFT=0
